# Database
DATABASE_URL=sqlite:///./data/dev.db
# For production: postgresql://user:pass@localhost/uniek_connect

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# API Server
API_HOST=127.0.0.1
API_PORT=61300
ENVIRONMENT=dev

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://192.168.42.21:61050

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:61300/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:61300/auth/microsoft/callback
MICROSOFT_TENANT=common

# Rate limiting (optional)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
